# Local release credentials — NOT committed to git.
#
# Setup (once):
#   cp packaging/release.sample.env packaging/release.env
#   chmod 600 packaging/release.env
#
# Put your App Store Connect API key (.p8) somewhere stable outside the repo, e.g.:
#   mkdir -p ~/.private_keys
#   mv ~/Downloads/AuthKey_XXXXX.p8 ~/.private_keys/
#
# Values from App Store Connect → Users and Access → Integrations → App Store Connect API.

# App Store Connect API key ID (e.g. 8839U8J32V)
APPLE_API_KEY_ID=

# Issuer UUID from the same API key page
APPLE_API_ISSUER=

# Absolute path to the .p8 file (tilde expands)
APPLE_API_KEY=$HOME/.private_keys/AuthKey_XXXXX.p8

# Optional — Developer ID Application identity for codesign (must match Keychain)
# CSC_NAME="Developer ID Application: Your Name (TEAMID)"
